    <rdf:Description rdf:about="http://www.semanticweb.org/fabio/ontologies/2026/4/untitled-ontology-2/m">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/fabio/ontologies/2026/4/untitled-ontology-2/d">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/fabio/ontologies/2026/4/untitled-ontology-2/d1">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/fabio/ontologies/2026/4/untitled-ontology-2/d2">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/fabio/ontologies/2026/4/untitled-ontology-2/d3">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment></rdfs:comment>
        <rdfs:label>MolestaG</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.discord.monitor/ontologia#Mensaje"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/fabio/ontologies/2026/4/untitled-ontology-2/m"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.discord.monitor/ontologia#tieneDeteccion"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/fabio/ontologies/2026/4/untitled-ontology-2/m"/>
                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/fabio/ontologies/2026/4/untitled-ontology-2/d"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                        <swrl:classPredicate rdf:resource="http://www.discord.monitor/ontologia#DeteccionMolestaGrave"/>
                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/fabio/ontologies/2026/4/untitled-ontology-2/d"/>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                        <swrl:propertyPredicate rdf:resource="http://www.discord.monitor/ontologia#tieneNivel"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/fabio/ontologies/2026/4/untitled-ontology-2/m"/>
                        <swrl:argument2 rdf:resource="http://www.discord.monitor/ontologia#riesgoModerado"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
        </swrl:head>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment></rdfs:comment>
        <rdfs:label>Scam dirigido a persona vulnerable</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.discord.monitor/ontologia#Mensaje"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/fabio/ontologies/2026/4/untitled-ontology-2/m"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.discord.monitor/ontologia#tieneDeteccion"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/fabio/ontologies/2026/4/untitled-ontology-2/m"/>
                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/fabio/ontologies/2026/4/untitled-ontology-2/d1"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                        <swrl:propertyPredicate rdf:resource="http://www.discord.monitor/ontologia#tieneDeteccion"/>
                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/fabio/ontologies/2026/4/untitled-ontology-2/m"/>
                                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/fabio/ontologies/2026/4/untitled-ontology-2/d2"/>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                        <rdf:first>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                                <swrl:classPredicate rdf:resource="http://www.discord.monitor/ontologia#DeteccionMolestaGrave"/>
                                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/fabio/ontologies/2026/4/untitled-ontology-2/d1"/>
                                            </rdf:Description>
                                        </rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                <rdf:first>
                                                    <rdf:Description>
